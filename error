    const savedEmail = localStorage.getItem("userEmail");

    if (savedEmail) {
      // User has an account → show Account
      navActionDesktop.textContent = "Account";
      navActionDesktop.href = "account.html";
      navActionMobile.textContent = "Account";
      navActionMobile.href = "account.html";
    } else {
      // No account → show Login / Sign Up
      navActionDesktop.textContent = "Login / Sign Up";
      navActionDesktop.href = "login.html";
      navActionMobile.textContent = "Login / Sign Up";
      navActionMobile.href = "login.html";
    }
  });
//pay courier
  document.addEventListener("DOMContentLoaded", () => {
    let courierTickets =
      JSON.parse(localStorage.getItem("courierTickets")) || [];
    const paymentDetails = document.getElementById("paymentDetails");

    // Utility: popup
    function showPopup(message) {
      // Remove any existing popup
      const existingPopup = document.querySelector(".custom-popup");
      if (existingPopup) existingPopup.remove();

      // Create popup container
      const popup = document.createElement("div");
      popup.className =
        "custom-popup fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50";

      popup.innerHTML = `
        <div class="bg-white rounded-lg shadow-lg p-6 max-w-sm w-full text-center">
          <p class="text-gray-800 font-medium mb-4">${message}</p>
          <button id="closePopup" 
            class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg">
            OK
          </button>
        </div>
      `;

      document.body.appendChild(popup);

      document.getElementById("closePopup").addEventListener("click", () => {
        popup.remove();
      });
    }

    if (courierTickets.length > 0) {
      const ticket = courierTickets[courierTickets.length - 1];
      paymentDetails.innerHTML = `
        <p><strong>Name:</strong> ${ticket.name}</p>
        <p><strong>Email:</strong> ${ticket.email}</p>
        <p><strong>Phone:</strong> ${ticket.phone}</p>
        <p><strong>Pickup:</strong> ${ticket.pickupStation}</p>
        <p><strong>Drop-off:</strong> ${ticket.dropoffStation}</p>
        <p><strong>Parcels:</strong> ${ticket.parcelCount}</p>
        <p><strong>Weight:</strong> ${ticket.weight} kg</p>
        <p><strong>Date:</strong> ${ticket.pickupDate}</p>
        <p><strong>Time:</strong> ${ticket.pickupTime}</p>
        <p><strong>Description:</strong> ${ticket.description}</p>
        <p><strong>Price:</strong> KES ${ticket.price}</p>
      `;
    } else {
      paymentDetails.innerHTML = "<p>No courier booking found.</p>";
    }

    // Pay Now
    document.getElementById("payBtn").onclick = () => {
      if (courierTickets.length === 0) {
        showPopup("⚠️ No courier booking found. Please book first.");
        return;
      }
      const ticket = courierTickets[courierTickets.length - 1];

      // Robust check if pickup date/time has passed
      const [year, month, day] = ticket.pickupDate.split("-").map(Number);
      const [hours, minutes] = ticket.pickupTime.split(":").map(Number);
      const departureDateTime = new Date(year, month - 1, day, hours, minutes);
      const now = new Date();

      if (now > departureDateTime) {
        showPopup(
          "⚠️ Sorry, this pickup time has already passed. Please book again with a valid future time."
        );
        return;
      }

      // Only runs if the time is valid
      setTimeout(() => {
        showTicket(ticket);
        showPopup("✅ Payment Successful! Your courier ticket is confirmed.");
      }, 1000);
    };

    // Cancel Ticket
    document.getElementById("cancelBtn").onclick = () => {
      if (courierTickets.length === 0) {
        showPopup("⚠️ No courier ticket available to cancel.");
        return;
      }
      const ticket = courierTickets[courierTickets.length - 1];
      courierTickets.pop();
      localStorage.setItem("courierTickets", JSON.stringify(courierTickets));

      document.getElementById("cancelMessage").classList.remove("hidden");
      document.getElementById("cancelDetails").innerHTML = `
        Courier ticket for <strong>${ticket.name}</strong> has been cancelled.<br>
        Refund of KES ${ticket.price} will be processed.
      `;
      document.getElementById("ticket").classList.add("hidden");

      showPopup("❌ Courier ticket cancelled. Refund will be processed.");
    };

    function showTicket(ticket) {
      document.getElementById("ticket").classList.remove("hidden");
      document.getElementById("ticketDetails").innerHTML = `
        ✅ Payment Successful!<br>
        Name: ${ticket.name}<br>
        Email: ${ticket.email}<br>
        Phone: ${ticket.phone}<br>
        Pickup: ${ticket.pickupStation}<br>
        Drop-off: ${ticket.dropoffStation}<br>
        Parcels: ${ticket.parcelCount}<br>
        Weight: ${ticket.weight} kg<br>
        Date: ${ticket.pickupDate}<br>
        Time: ${ticket.pickupTime}<br>
        Description: ${ticket.description}<br>
        Price: KES ${ticket.price}
      `;
    }
  });
</script>


